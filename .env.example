# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls.
NEXT_PUBLIC_GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# SQLITE_URL: The connection string for the Prisma database.
# For Docker deployment, this will be overridden in docker-compose.yml
SQLITE_URL="file:./dev.db"

# ENCRYPTION_KEY: 32-byte key for encrypting sensitive data like API keys.
ENCRYPTION_KEY="12345678901234567890123456789012"

# JWT_SECRET: Secret key for signing JWT tokens.
JWT_SECRET="your-super-secret-jwt-key-change-me-in-production"
